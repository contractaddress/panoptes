  <div class="icon-row">
    {icons.map(iconName => (
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        {iconName === 'server' && (
          <>
            <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
            <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
            <line x1="6" y1="6" x2="6" y2="6"></line>
            <line x1="6" y1="18" x2="6" y2="18"></line>
          </>
        )}
        {iconName === 'network' && (
          <>
            <rect x="16" y="16" width="8" height="8" rx="2" ry="2"></rect>
            <rect x="2" y="16" width="8" height="8" rx="2" ry="2"></rect>
            <rect x="9" y="2" width="8" height="8" rx="2" ry="2"></rect>
            <line x1="6" y1="16" x2="6" y2="16"></line>
            <line x1="18" y1="16" x2="18" y2="16"></line>
          </>
        )}
        {iconName === 'storage' && (
          <>
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </>
        )}
        {iconName === 'cpu' && (
          <>
            <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
            <rect x="9" y="9" width="6" height="6"></rect>
            <line x1="9" y1="1" x2="9" y2="4"></line>
            <line x1="15" y1="1" x2="15" y2="4"></line>
            <line x1="9" y1="20" x2="9" y2="23"></line>
            <line x1="15" y1="20" x2="15" y2="23"></line>
            <line x1="20" y1="9" x2="23" y2="9"></line>
            <line x1="20" y1="14" x2="23" y2="14"></line>
            <line x1="1" y1="9" x2="4" y2="9"></line>
            <line x1="1" y1="14" x2="4" y2="14"></line>
          </>
        )}
        {iconName === 'memory' && (
          <>
            <rect x="2" y="2" width="8" height="4" rx="1" ry="1"></rect>
            <rect x="2" y="10" width="8" height="4" rx="1" ry="1"></rect>
            <rect x="2" y="18" width="8" height="4" rx="1" ry="1"></rect>
            <rect x="14" y="6" width="8" height="4" rx="1" ry="1"></rect>
            <rect x="14" y="14" width="8" height="4" rx="1" ry="1"></rect>
          </>
        )}
        {iconName === 'temperature' && (
          <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"></path>
        )}
        {iconName === 'power' && (
          <>
            <path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path>
            <line x1="12" y1="2" x2="12" y2="12"></line>
          </>
        )}
        {iconName === 'settings' && (
          <>
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
          </>
        )}
        {iconName === 'docker' && (
          <>
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12z"></path>
            <path d="M4 11h16v2H4z"></path>
            <path d="M4 7h16v2H4z"></path>
            <path d="M8 7v8"></path>
            <path d="M12 7v8"></path>
            <path d="M16 7v8"></path>
          </>
        )}
        {iconName === 'alert' && (
          <>
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </>
        )}
      </svg>
    ))}
  </div>


<!--
  Dashboard Card Component
  Props:
    - title: Card title/label
    - status: 'online', 'offline', or 'warning'
    - icon: Path to icon/logo image
    - isHero: Boolean for hero card styling

  Slots:
    - default: Hero-specific content (info cards, etc.)
    - icon: Custom icon rendering (overrides icon prop)
-->

---
import { getStatusTooltip } from '../utils/statusTooltip.js';

const { title, status = 'online', icon = null, isHero = false } = Astro.props;
---

<div class={`dashboard-card ${isHero ? 'hero-card' : 'small-tile-card'}`}>
  <div class={`status-indicator status-${status}`} title={getStatusTooltip(status)}></div>
  <div class={`${isHero ? 'card-label hero-label' : 'small-card-label'}`}>{title}</div>

  {!isHero && icon && (
  <div class={`tile-icon ${title}`}>
      <img src={icon} alt={title} />
    </div>
  )}

  {isHero && (
    <div class="hero-info">
      <div class="hero-logo">
        <slot name="icon">
          {icon && <img class="proxmox-icon" src={icon} alt={title} />}
        </slot>
      </div>
      <slot />
    </div>
  )}
</div>

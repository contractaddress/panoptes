---
import { getStatusTooltip, getImageStyleClass } from '../utils/statusTooltip.js';

const { title, status = 'online', logos = [] } = Astro.props;
---

<div class="dashboard-card services-card">
  <div class={`status-indicator status-${status}`} title={getStatusTooltip(status)}></div>
  <div class="card-label hero-label">{title}</div>
  <div class="logo-grid">
    {logos.map((logo) => {
      const serviceId = `service_${logo.name}`;
      return (
        <div class="logo-box" data-service-id={serviceId}>
          {logo.icon && <img
            src={logo.icon}
            alt={logo.name}
            title={logo.name}
            class={getImageStyleClass(logo.status || 'online')}
            data-status-image
          />}
        </div>
      );
    })}
  </div>
</div>
